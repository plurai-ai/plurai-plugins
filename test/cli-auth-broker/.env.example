# Copy to .env.local and fill in.
# .env.local is gitignored.

# Clerk publishable key for the instance you're testing against.
# Find it in the Clerk dashboard → API keys (Publishable key, starts with pk_test_ or pk_live_).
#
# The Clerk dashboard's "Authorized origins" list MUST include the origin you
# serve this app from (e.g. http://127.0.0.1:5173 for local dev,
# https://pluto.stg.plurai.ai for staging). Without it, getToken() fails the
# CORS preflight and the page surfaces a misleading "mint failed" error.
VITE_CLERK_PUBLISHABLE_KEY=

# Note: the JWT template name, redirect-host allowlist, and redirect-port
# allowlist are intentionally hard-coded in src/. They cannot be overridden
# by env vars in production builds.
