{
  "name": "cli-auth-broker",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Production broker page for Pluto CLI authentication. See ../../docs/rfcs/0001-web-broker-cli-auth.md.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:check": "tsc -b --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:flow": "node test-flow.js",
    "audit": "npm audit --audit-level=high",
    "ci": "npm ci && npm run build:check && npm run audit && npm run test && npm run build"
  },
  "dependencies": {
    "@clerk/clerk-react": "5.18.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "16.1.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "jsdom": "25.0.1",
    "typescript": "5.7.2",
    "vite": "5.4.21",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
